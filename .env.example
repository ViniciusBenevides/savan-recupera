# SAVAN Recupera — variáveis de ambiente (raiz)
# Copie para `.env` e preencha. NUNCA commite o `.env` real.
# Formato: "chave: valor" (lido por import/importar_planilha.py e n8n/criar_workflows.py).

# --- Asaas ---
chave api asaas (sandbox):
token webhook asaas:

# --- Chatwoot ---
token chatwoot:
chatwoot url: https://<seu-chatwoot>/

# --- Z-API ---
token z-api:
url z-api: https://app.z-api.io/

# --- Supabase ---
service_role supabase:
supabase api url: https://<SUPABASE_PROJECT_REF>.supabase.co
url supabase: https://supabase.com/dashboard/project/<SUPABASE_PROJECT_REF>/settings/api-keys/legacy

# --- Salvy ---
url salvy: https://salvy.com.br/

# --- n8n ---
url n8n: https://<seu-n8n>/
email n8n:
senha n8n:
n8n api key:
