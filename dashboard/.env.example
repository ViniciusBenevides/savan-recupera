# Dashboard (Next.js) — variáveis de ambiente
# Copie para `.env.local` e preencha. NUNCA commite o `.env.local` real.
# As mesmas variáveis ficam configuradas no projeto da Vercel (produção).

# Nome do produto exibido no painel (white-label). Padrão: "Recupera".
# Use uma ou duas palavras — a 2ª palavra ganha destaque em verde no logo.
NEXT_PUBLIC_APP_NAME=Recupera

NEXT_PUBLIC_SUPABASE_URL=https://<SUPABASE_PROJECT_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Fallback do Token de Segurança da Z-API. Cada chip informa o seu no cadastro
# (multi-conta); este env só é usado para chips que não tiverem o token gravado.
ZAPI_CLIENT_TOKEN=
CHATWOOT_URL=https://<seu-chatwoot>
CHATWOOT_TOKEN=
CHATWOOT_ACCOUNT_ID=1
